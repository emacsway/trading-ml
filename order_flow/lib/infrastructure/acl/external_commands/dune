(library
 (name order_flow_external_commands)
 (public_name trading.order_flow.acl.external_commands)
 (libraries yojson ppx_yojson_conv_lib atdgen-runtime core bus)
 (preprocess
  (pps ppx_yojson_conv))
 (flags
  (:standard -open Ppx_yojson_conv_lib.Yojson_conv.Primitives)))

; Outbound to the broker BC. Regenerated from the consumer's (broker BC)
; .atd contract — the order_flow BC mirrors it independently (ADR 0001),
; byte-for-byte wire shape match, no code-level dependency.
(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/commands/watch_public_trades_command.atd))
 (targets watch_public_trades_command_t.ml watch_public_trades_command_t.mli
          watch_public_trades_command_j.ml watch_public_trades_command_j.mli)
 (action
  (progn
   (run atdgen -t -o watch_public_trades_command %{atd})
   (run atdgen -j -o watch_public_trades_command %{atd}))))

(rule
 (deps
  (:atd %{project_root}/shared/contracts/broker/commands/unwatch_public_trades_command.atd))
 (targets unwatch_public_trades_command_t.ml unwatch_public_trades_command_t.mli
          unwatch_public_trades_command_j.ml unwatch_public_trades_command_j.mli)
 (action
  (progn
   (run atdgen -t -o unwatch_public_trades_command %{atd})
   (run atdgen -j -o unwatch_public_trades_command %{atd}))))
