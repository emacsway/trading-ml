(* Wire contract: strategy/lib/application/view_models/candle_view_model.ml

   NOTE: ts is int64 (epoch seconds), diverging from broker's
   candle_view_model where ts is iso8601 string. Asymmetry inherited
   from older epoch — to be reconciled when the bar feed contract
   is aligned across BCs. *)

type t = {
  ts : int <ocaml repr="int64">;
  open_ <json name="open"> : string;
  high : string;
  low : string;
  close : string;
  volume : string;
}
