(* Wire contract: paper_broker/lib/application/view_models/candle_view_model.ml

   Mirror of broker/view_models/candle_view_model.atd — paper_broker
   stands in for broker in backtest mode; both BCs share an
   identical bar-data wire shape so the same producer can target
   either backend. *)

type t = {
  ts : string;
  open_ <json name="open"> : string;
  high : string;
  low : string;
  close : string;
  volume : string;
}
